@model List<Entidades.Herramienta>
@{
    ViewData["Title"] = "Herramientas";
}
@*Una vista puede tener un solo Modelo o sea una sola entidad (entidad simple o compuesta)*@

<h1>BIENVENIDO A FERRETERIA: "MANNY A LA OBRA"</h1>
<a class="btn btn-primary" asp-action="Crear">Agregar una nueva herramienta</a>

<table class= "table" >
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Imagen</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var herramienta in Model)
        {
            <tr>
                <td>@herramienta.Descripcion</td>
                <td>@herramienta.Precio.ToString("C")</td>
                <td><img src="@herramienta.Imagen" alt="@herramienta.Descripcion" width="100"/></td>

                <td>
                    <a class="btn btn-danger" asp-action="Eliminar" asp-route-id="@herramienta.Id">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
    
</table>